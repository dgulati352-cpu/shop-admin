rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /orders/{orderId} {
      allow read, write: if true;
    }
    match /customers/{email} {
      allow read, write: if true;
    }
    match /promoCodes/{promoId} {
      allow read, write: if true;
    }
    match /articles/{articleId} {
      allow read, write: if true;
    }
    match /products/{productId} {
      allow read, write: if true;
    }
  }
}
